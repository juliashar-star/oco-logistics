# Скопируйте в корень проекта как .env и заполните значения.
# cp infra/.env.example .env   (Linux/macOS)
# copy infra\.env.example .env (Windows)

# PostgreSQL (локально — значения из infra/docker-compose.yml)
DATABASE_URL="postgresql://oco:oco_dev_password@localhost:5432/oco_logistics?schema=public"

# APIShip — только на сервере, не в браузере
# Тестовая песочница (публичные учётные данные для разработки):
APISHIP_BASE_URL="http://api.dev.apiship.ru/v1/"
APISHIP_LOGIN="test"
APISHIP_PASSWORD="test"
# Бой (M4): https://api.apiship.ru/v1/ + логин/пароль из личного кабинета APIShip

# Шифрование пароля APIShip в базе (apishipPasswordEnc) — длинная случайная строка, мин. 32 символа
APISHIP_ENCRYPTION_KEY="change-me-to-another-long-random-string-32chars-min"

# Сессии / авторизация (случайная строка минимум 16 символов)
AUTH_SECRET="change-me-to-a-long-random-string"

# DaData — подсказки адреса (только на сервере, не в браузере)
DADATA_API_KEY=        # dadata.ru → личный кабинет → API-ключи

# Окружение
NODE_ENV="development"
